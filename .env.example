# Copy this file to .env and fill in your values

JWT_SECRET=your_jwt_secret_here
EXPIRATION_TIME=28800000
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here

# ── DynamoDB tables ───────────────────────────────────────────────────────────
DYNAMODB_USERS_TABLE=claimflow-users
DYNAMODB_CLAIMS_TABLE=claimflow-claims

# ── Set to true to use in-memory mock instead of DynamoDB ────────────────────
USE_MOCK_DB=false

# ── Bedrock Agent IDs (fill in once agents are set up in AWS Console) ─────────
VISION_AGENT_ID=PLACEHOLDER
VISION_AGENT_ALIAS=PLACEHOLDER
FORENSIC_AGENT_ID=PLACEHOLDER
FORENSIC_AGENT_ALIAS=PLACEHOLDER
AGENT_CORE_AGENT_ID=PLACEHOLDER
AGENT_CORE_AGENT_ALIAS=PLACEHOLDER
GUARDRAIL_ID=PLACEHOLDER
GUARDRAIL_VERSION=DRAFT
